__pycache__/
*.py[cod]
*$py.class
*.pyc

# Data (runtime only — never committed or submitted)
data/
solution/data/

# Runtime artifacts (regenerated by the pipeline)
artifacts/
solution/artifacts/

# Virtual environments
.venv/
venv/
env/

# OS / editor cruft
.DS_Store
Thumbs.db
